{
    "name": "quiz-proto",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "server": "clear && nodemon src/server/main.js",
        "client": "clear && node src/client/client.js",
        "test": "clear && node --test tests/**/*.test.js --test-timeout=5000 --test-concurrency=1",
        "test:watch": "clear && node --test --watch tests/**/*.test.js --test-timeout=5000 --test-concurrency=1",
        "test:report": "clear && node --test --test-reporter=spec tests/**/*.test.js"
    },
    "dependencies": {
        "express": "^5.2.1",
        "ws": "^8.19.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "nodemon": "^3.1.11"
    }
}
